---
import Layout from '../layouts/Layout.astro';
import ProjectModal from '../components/ProjectModal.astro';
import { projects } from '../data/projects.js';
import { experiences } from '../data/experience.js'; // Nueva data
import { certificates} from "../data/certifications";
import AllCertsModal from '../components/AllCertsModal.astro';
import ClickMe from '../components/ClickMe.svelte';
import ColorPaletteSwitcher from '../components/ColorPaletteSwitcher.svelte';
---

<Layout title="Angel | Fullstack Developer">
    <!-- Sticky Navigation / Roadmap -->
    <nav class="fixed top-4 left-1/2 -translate-x-1/2 z-50 bg-neutral-900/80 backdrop-blur-lg border border-neutral-800 rounded-full px-4 py-2 shadow-2xl">
        <ul class="flex items-center gap-1">
            <li><a href="#hero" class="nav-link text-[10px] md:text-xs px-3 py-1.5 rounded-full text-neutral-400 hover:text-white hover:bg-neutral-800 transition-all">Inicio</a></li>
            <li><a href="#about" class="nav-link text-[10px] md:text-xs px-3 py-1.5 rounded-full text-neutral-400 hover:text-white hover:bg-neutral-800 transition-all">Sobre Mí</a></li>
            <li><a href="#skills" class="nav-link text-[10px] md:text-xs px-3 py-1.5 rounded-full text-neutral-400 hover:text-white hover:bg-neutral-800 transition-all">Skills</a></li>
            <li><a href="#experiencia" class="nav-link text-[10px] md:text-xs px-3 py-1.5 rounded-full text-neutral-400 hover:text-white hover:bg-neutral-800 transition-all">Experiencia</a></li>
            <li><a href="#proyectos" class="nav-link text-[10px] md:text-xs px-3 py-1.5 rounded-full text-neutral-400 hover:text-white hover:bg-neutral-800 transition-all">Proyectos</a></li>
            <li><a href="#certificaciones" class="nav-link text-[10px] md:text-xs px-3 py-1.5 rounded-full text-neutral-400 hover:text-white hover:bg-neutral-800 transition-all">Certs</a></li>
            <li><a href="#contacto" class="nav-link text-[10px] md:text-xs px-3 py-1.5 rounded-full text-neutral-400 hover:text-white hover:bg-neutral-800 transition-all">Contacto</a></li>
        </ul>
        <!-- Progress bar -->
        <div class="absolute bottom-0 left-0 h-0.5 bg-gradient-to-r from-emerald-500 to-cyan-500 rounded-full transition-all duration-300" id="progress-bar"></div>
    </nav>

    <main class="max-w-6xl w-full mx-auto p-4 md:p-8">

        <!-- SECCIÓN 1: HERO + CONTACTO -->
        <section id="hero" class="min-h-screen flex flex-col justify-center mb-20 relative">
            <!-- Decorative background elements -->
            <div class="absolute top-20 left-0 w-96 h-96 bg-emerald-500/5 rounded-full blur-3xl pointer-events-none"></div>
            <div class="absolute bottom-0 right-0 w-96 h-96 bg-cyan-500/5 rounded-full blur-3xl pointer-events-none"></div>

            <header class="mb-8 relative z-10">
                <h1 class="text-5xl md:text-7xl font-bold tracking-tighter mb-4 animate-slide-in-left">
                    Hola, soy <span class="text-transparent bg-clip-text bg-gradient-to-r from-emerald-400 to-cyan-600">Luis Ángel Cardona</span>.
                </h1>
            </header>

            <div class="mb-12 relative z-10">
                <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 items-start">
                    <div class="lg:col-span-2">
                        <div class="absolute -left-4 top-1 h-12 w-1 bg-gradient-to-b from-emerald-500 to-transparent rounded-full hidden md:block"></div>

                        <p class="text-xl md:text-2xl text-neutral-400 font-light leading-relaxed mb-6 animate-slide-in-bottom" style="animation-delay: 0.1s">
                            Desarrollador de Software <span class="text-white font-medium">FullStack</span>.
                            <br class="hidden md:block" />
                            Actualmente construyendo proyectos orientados al datacycle, en transición a <span class="text-emerald-400 font-medium">Ingeniería de Datos</span>.
                        </p>
                    </div>

                </div>

                <div class="flex flex-wrap gap-4 items-center">
                    <div class="flex items-center gap-2 text-sm text-emerald-400 bg-emerald-900/20 px-3 py-1.5 rounded-lg border border-emerald-500/20">
                        <span class="relative flex h-2 w-2">
                          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                          <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
                        </span>
                        Disponible para nuevos retos
                    </div>

                    <div class="flex items-center gap-2 text-sm text-emerald-400 bg-emerald-900/20 px-3 py-1.5 rounded-lg border border-emerald-500/20">
                        <span class="relative flex h-2 w-2">
                          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                          <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
                        </span>
                        Inglés: B2
                    </div>

                    <div class="flex items-center gap-2 text-sm text-gray-400 bg-white/5 px-3 py-1.5 rounded-lg border border-white/10">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m5 11 4-7"/><path d="m19 13-4 7"/><path d="M14 11h5.5a1.5 1.5 0 0 1 1.5 1.5v3.5a1.5 1.5 0 0 1-1.5 1.5H14v-5z"/><path d="M10 13H4.5a1.5 1.5 0 0 1-1.5-1.5v-3.5a1.5 1.5 0 0 1 1.5-1.5H10v5z"/></svg>
                        Ingeniería de Datos
                    </div>

                    <div class="flex items-center gap-2 text-sm text-gray-400 bg-white/5 px-3 py-1.5 rounded-lg border border-white/10">
                      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 1 1 18 0z"/>
                        <circle cx="12" cy="10" r="2"/>
                      </svg>
                      Honduras, Tegucigalpa
                    </div>
                </div>
            </div>

            <!-- Contacto -->
            <div class="flex flex-wrap gap-4 relative z-10 animate-slide-in-bottom" style="animation-delay: 0.3s">
                <a href="mailto:angel2.cardona@outlook.com" class="group flex items-center gap-3 bg-gradient-to-r from-emerald-500/10 to-cyan-500/10 hover:from-emerald-500/20 hover:to-cyan-500/20 border border-emerald-500/30 hover:border-emerald-400/60 px-6 py-3 rounded-xl transition-all duration-300 shadow-lg hover:shadow-emerald-500/20">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-emerald-400 group-hover:scale-110 transition-transform"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                    <span class="text-sm font-medium">Email</span>
                </a>

                <a href="http://www.linkedin.com/in/luis-ángel-cardona-4922412b6" target="_blank" class="group flex items-center gap-3 bg-gradient-to-r from-emerald-500/10 to-cyan-500/10 hover:from-emerald-500/20 hover:to-cyan-500/20 border border-emerald-500/30 hover:border-emerald-400/60 px-6 py-3 rounded-xl transition-all duration-300 shadow-lg hover:shadow-emerald-500/20">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" class="text-emerald-400 group-hover:scale-110 transition-transform"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                    <span class="text-sm font-medium">LinkedIn</span>
                </a>
            </div>

            <!-- Scroll indicator -->
            <div class="mt-16 flex justify-center relative z-10">
                <a href="#about" class="animate-bounce text-emerald-400 hover:text-emerald-300 transition-colors">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
                </a>
            </div>
        </section>

        <!-- SECCIÓN 2: SOBRE MÍ -->
        <section id="about" class="mb-32">
            <div class="mb-12">
                <h2 class="text-3xl md:text-5xl font-bold mb-4">
                    Sobre <span class="text-emerald-400">Mí</span>
                </h2>
                <p class="text-neutral-400 max-w-2xl">Mi journey y lo que me motiva</p>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
                <!-- Bio card -->
                <div class="bg-gradient-to-br from-neutral-900/50 to-neutral-900/30 border border-neutral-800 hover:border-emerald-500/50 rounded-2xl p-8 hover:shadow-lg hover:shadow-emerald-500/10 transition-all duration-300">
                    <div class="flex items-center gap-3 mb-6">
                        <div class="w-12 h-12 bg-emerald-500/20 rounded-xl flex items-center justify-center">
                            <svg class="w-6 h-6 text-emerald-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                        </div>
                        <h3 class="text-xl font-bold text-white">Mi Historia</h3>
                    </div>

                    <p class="text-neutral-300 leading-relaxed mb-4">
                        Soy un desarrollador <span class="text-emerald-400 font-medium">FullStack</span> con residencia en Tegucigalpa, Honduras. Me gusta hacer proyectos cools cuando estoy aburrido.
                    </p>

                    <p class="text-neutral-300 leading-relaxed mb-4">
                        Actualmente estoy en transición hacia <span class="text-emerald-400 font-medium">Ingeniería de Datos</span>, combinando mi experiencia en desarrollo con nuevas habilidades en procesamiento, almacenamiento y análisis de datos a escala.
                    </p>
                    <p class="text-neutral-300 leading-relaxed mb-4">
                        Fuera de la informatica, me gusta leer, organizar, el gym y me gusta la fotografia.
                    </p>
                </div>

                <!-- Stats & Focus card -->
                <div class="space-y-6">
                    <!-- Stats grid -->
                    <div class="grid grid-cols-2 gap-4">
                        <div class="bg-gradient-to-br from-emerald-500/10 to-cyan-500/10 border border-emerald-500/30 rounded-2xl p-6 text-center">
                            <p class="text-4xl font-black text-emerald-400 mb-1">3+</p>
                            <p class="text-neutral-400 text-sm">Años de experiencia</p>
                        </div>
                        <div class="bg-gradient-to-br from-cyan-500/10 to-blue-500/10 border border-cyan-500/30 rounded-2xl p-6 text-center">
                            <p class="text-4xl font-black text-cyan-400 mb-1">10+</p>
                            <p class="text-neutral-400 text-sm">Proyectos completados</p>
                        </div>
                        <div class="bg-gradient-to-br from-violet-500/10 to-purple-500/10 border border-violet-500/30 rounded-2xl p-6 text-center">
                            <p class="text-4xl font-black text-violet-400 mb-1">4+</p>
                            <p class="text-neutral-400 text-sm">Certificaciones</p>
                        </div>
                        <div class="bg-gradient-to-br from-orange-500/10 to-red-500/10 border border-orange-500/30 rounded-2xl p-6 text-center">
                            <p class="text-4xl font-black text-orange-400 mb-1">∞</p>
                            <p class="text-neutral-400 text-sm">Curiosidad</p>
                        </div>
                    </div>

                    <!-- Focus areas -->
                    <div class="bg-gradient-to-br from-neutral-900/50 to-neutral-900/30 border border-neutral-800 hover:border-emerald-500/50 rounded-2xl p-6 hover:shadow-lg hover:shadow-emerald-500/10 transition-all duration-300">
                        <div class="flex items-center gap-3 mb-4">
                            <div class="w-10 h-10 bg-emerald-500/20 rounded-lg flex items-center justify-center">
                                <svg class="w-5 h-5 text-emerald-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
                            </div>
                            <h3 class="text-lg font-bold text-white">Lo que me motiva</h3>
                        </div>

                        <ul class="space-y-3">
                            <li class="flex items-start gap-3 text-neutral-300 text-sm">
                                <span class="text-emerald-400 mt-1">▹</span>
                                <span>Transformar datos complejos en insights accionables</span>
                            </li>
                            <li class="flex items-start gap-3 text-neutral-300 text-sm">
                                <span class="text-emerald-400 mt-1">▹</span>
                                <span>Construir arquitecturas escalables y eficientes</span>
                            </li>
                            <li class="flex items-start gap-3 text-neutral-300 text-sm">
                                <span class="text-emerald-400 mt-1">▹</span>
                                <span>Aprender continuamente y compartir conocimiento</span>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </section>

        <!-- SECCIÓN 3: SKILLS -->
        <section id="skills" class="mb-32">
            <div class="mb-12">
                <h2 class="text-3xl md:text-5xl font-bold mb-4">
                    Habilidades <span class="text-emerald-400">Técnicas</span>
                </h2>
                <p class="text-neutral-400 max-w-2xl">Stack tecnológico que domino y utilizo</p>
            </div>

            <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 gap-4">
                <!-- Frontend -->
                <div class="group bg-gradient-to-br from-neutral-900/50 to-neutral-900/30 border border-neutral-800 hover:border-emerald-500/50 rounded-2xl p-6 flex flex-col items-center justify-center gap-3 hover:shadow-lg hover:shadow-emerald-500/10 transition-all duration-300 hover:-translate-y-1">
                    <div class="w-12 h-12 bg-gradient-to-br from-cyan-500/20 to-blue-500/20 rounded-xl flex items-center justify-center group-hover:scale-110 transition-transform">
                        <svg class="w-6 h-6 text-cyan-400" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
                    </div>
                    <span class="text-sm font-medium text-neutral-300">React</span>
                </div>

                <div class="group bg-gradient-to-br from-neutral-900/50 to-neutral-900/30 border border-neutral-800 hover:border-emerald-500/50 rounded-2xl p-6 flex flex-col items-center justify-center gap-3 hover:shadow-lg hover:shadow-emerald-500/10 transition-all duration-300 hover:-translate-y-1">
                    <div class="w-12 h-12 bg-gradient-to-br from-cyan-500/20 to-cyan-400/20 rounded-xl flex items-center justify-center group-hover:scale-110 transition-transform">
                        <svg class="w-6 h-6 text-cyan-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
                    </div>
                    <span class="text-sm font-medium text-neutral-300">TypeScript</span>
                </div>

                <div class="group bg-gradient-to-br from-neutral-900/50 to-neutral-900/30 border border-neutral-800 hover:border-emerald-500/50 rounded-2xl p-6 flex flex-col items-center justify-center gap-3 hover:shadow-lg hover:shadow-emerald-500/10 transition-all duration-300 hover:-translate-y-1">
                    <div class="w-12 h-12 bg-gradient-to-br from-violet-500/20 to-purple-500/20 rounded-xl flex items-center justify-center group-hover:scale-110 transition-transform">
                        <svg class="w-6 h-6 text-violet-400" viewBox="0 0 24 24" fill="currentColor"><path d="M3 3h18v18H3V3zm16.5 15.5V5.5H4.5v13h15z"/><path d="M6 6h12v12H6V6z"/></svg>
                    </div>
                    <span class="text-sm font-medium text-neutral-300">Astro</span>
                </div>

                <div class="group bg-gradient-to-br from-neutral-900/50 to-neutral-900/30 border border-neutral-800 hover:border-emerald-500/50 rounded-2xl p-6 flex flex-col items-center justify-center gap-3 hover:shadow-lg hover:shadow-emerald-500/10 transition-all duration-300 hover:-translate-y-1">
                    <div class="w-12 h-12 bg-gradient-to-br from-orange-500/20 to-red-500/20 rounded-xl flex items-center justify-center group-hover:scale-110 transition-transform">
                        <svg class="w-6 h-6 text-orange-400" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
                    </div>
                    <span class="text-sm font-medium text-neutral-300">Tailwind</span>
                </div>

                <!-- Backend -->
                <div class="group bg-gradient-to-br from-neutral-900/50 to-neutral-900/30 border border-neutral-800 hover:border-emerald-500/50 rounded-2xl p-6 flex flex-col items-center justify-center gap-3 hover:shadow-lg hover:shadow-emerald-500/10 transition-all duration-300 hover:-translate-y-1">
                    <div class="w-12 h-12 bg-gradient-to-br from-green-500/20 to-emerald-500/20 rounded-xl flex items-center justify-center group-hover:scale-110 transition-transform">
                        <svg class="w-6 h-6 text-green-400" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/></svg>
                    </div>
                    <span class="text-sm font-medium text-neutral-300">Node.js</span>
                </div>

                <div class="group bg-gradient-to-br from-neutral-900/50 to-neutral-900/30 border border-neutral-800 hover:border-emerald-500/50 rounded-2xl p-6 flex flex-col items-center justify-center gap-3 hover:shadow-lg hover:shadow-emerald-500/10 transition-all duration-300 hover:-translate-y-1">
                    <div class="w-12 h-12 bg-gradient-to-br from-blue-500/20 to-cyan-500/20 rounded-xl flex items-center justify-center group-hover:scale-110 transition-transform">
                        <svg class="w-6 h-6 text-blue-400" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/></svg>
                    </div>
                    <span class="text-sm font-medium text-neutral-300">Python</span>
                </div>

                <!-- Database -->
                <div class="group bg-gradient-to-br from-neutral-900/50 to-neutral-900/30 border border-neutral-800 hover:border-emerald-500/50 rounded-2xl p-6 flex flex-col items-center justify-center gap-3 hover:shadow-lg hover:shadow-emerald-500/10 transition-all duration-300 hover:-translate-y-1">
                    <div class="w-12 h-12 bg-gradient-to-br from-amber-500/20 to-orange-500/20 rounded-xl flex items-center justify-center group-hover:scale-110 transition-transform">
                        <svg class="w-6 h-6 text-amber-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/></svg>
                    </div>
                    <span class="text-sm font-medium text-neutral-300">PostgreSQL</span>
                </div>

                <div class="group bg-gradient-to-br from-neutral-900/50 to-neutral-900/30 border border-neutral-800 hover:border-emerald-500/50 rounded-2xl p-6 flex flex-col items-center justify-center gap-3 hover:shadow-lg hover:shadow-emerald-500/10 transition-all duration-300 hover:-translate-y-1">
                    <div class="w-12 h-12 bg-gradient-to-br from-red-500/20 to-pink-500/20 rounded-xl flex items-center justify-center group-hover:scale-110 transition-transform">
                        <svg class="w-6 h-6 text-red-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/></svg>
                    </div>
                    <span class="text-sm font-medium text-neutral-300">MySQL</span>
                </div>

                <div class="group bg-gradient-to-br from-neutral-900/50 to-neutral-900/30 border border-neutral-800 hover:border-emerald-500/50 rounded-2xl p-6 flex flex-col items-center justify-center gap-3 hover:shadow-lg hover:shadow-emerald-500/10 transition-all duration-300 hover:-translate-y-1">
                    <div class="w-12 h-12 bg-gradient-to-br from-emerald-500/20 to-green-500/20 rounded-xl flex items-center justify-center group-hover:scale-110 transition-transform">
                        <svg class="w-6 h-6 text-emerald-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/></svg>
                    </div>
                    <span class="text-sm font-medium text-neutral-300">MongoDB</span>
                </div>

                <!-- Tools -->
                <div class="group bg-gradient-to-br from-neutral-900/50 to-neutral-900/30 border border-neutral-800 hover:border-emerald-500/50 rounded-2xl p-6 flex flex-col items-center justify-center gap-3 hover:shadow-lg hover:shadow-emerald-500/10 transition-all duration-300 hover:-translate-y-1">
                    <div class="w-12 h-12 bg-gradient-to-br from-orange-500/20 to-red-500/20 rounded-xl flex items-center justify-center group-hover:scale-110 transition-transform">
