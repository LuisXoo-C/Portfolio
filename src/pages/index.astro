    <!-- Navigation scripts -->
    <script>
        // Active nav link highlighting + progress bar
        const sections = document.querySelectorAll('section[id]');
        const navLinks = document.querySelectorAll('.nav-link');
        const progressBar = document.getElementById('progress-bar');

        const observerOptions = {
            root: null,
            rootMargin: '-50% 0px',
            threshold: 0
        };

        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    navLinks.forEach(link => {
                        link.classList.remove('text-white', 'bg-emerald-500/20', 'border', 'border-emerald-500/40');
                        link.classList.add('text-neutral-400');
                        if (link.getAttribute('href') === `#${entry.target.id}`) {
                            link.classList.remove('text-neutral-400');
                            link.classList.add('text-white', 'bg-emerald-500/20', 'border', 'border-emerald-500/40');
                        }
                    });
                }
            });
        }, observerOptions);

        sections.forEach(section => observer.observe(section));

        // Progress bar based on scroll
        window.addEventListener('scroll', () => {
            const scrollTop = window.scrollY;
            const docHeight = document.body.scrollHeight - window.innerHeight;
            const scrollPercent = (scrollTop / docHeight) * 100;
            progressBar.style.width = scrollPercent + '%';
        });
    </script>

